{
  "schemaVersion": 2,
  "dockerfileLines": [
    "FROM node:20.9.0-alpine AS builder",
    "WORKDIR /usr/src/app",
    "COPY package*.json ./",
    "RUN npm install",
    "COPY . .",
    "RUN npm run build",
    "FROM node:20.9.0-alpine AS runner",
    "WORKDIR /usr/src/app",
    "ENV NODE_ENV=production",
    "COPY --from=builder /usr/src/app ./",
    "EXPOSE 3000",
    "CMD [\"npm\", \"start\"]"
  ]
}